{
  "name": "tg-tagauto",
  "version": "1.0.0",
  "private": true,
  "description": "mtcute Telegram profile sync example for Cloudflare Workers",
  "main": "dist/src/generate-session.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.worker.json",
    "generate:session": "ts-node src/generate-session.ts",
    "worker:dev": "wrangler dev",
    "worker:check": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@mtcute/convert": "^0.29.5",
    "@mtcute/node": "^0.29.5",
    "@mtcute/wasm": "^0.29.0",
    "@mtcute/web": "^0.29.5",
    "buffer": "^6.0.3",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/node": "^24.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.11.1"
  }
}
